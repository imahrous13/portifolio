# Copy this file to .env and fill in your details

# Gmail address to send from
EMAIL_USER=your.name@gmail.com

# Gmail App Password (NOT your normal password)
# Create at: https://myaccount.google.com/apppasswords (requires 2-Step Verification)
EMAIL_PASS=your_16_char_app_password

# Optional: custom From header (defaults to EMAIL_USER)
# Example: "Your Name <your.name@gmail.com>"
EMAIL_FROM=

# Default recipient (falls back to the target address if unset)
DEFAULT_TO=imahrous13@gmail.com

# SMTP server settings (Gmail defaults)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false

